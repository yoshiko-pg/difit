{
  "name": "difit",
  "displayName": "difit",
  "version": "0.1.0",
  "description": "GitHub-like diff review inside VS Code. difit is bundled — no extra install needed.",
  "categories": [
    "Other"
  ],
  "homepage": "https://github.com/yoshiko-pg/difit",
  "bugs": {
    "url": "https://github.com/yoshiko-pg/difit/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yoshiko-pg/difit.git"
  },
  "publisher": "yoshiko-pg",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "package": "pnpm --dir ../.. run build && node build.mjs && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@parcel/watcher": "^2.5.1",
    "@types/node": "^24.0.8",
    "@types/vscode": "^1.102.0",
    "@vscode/vsce": "^3.6.2",
    "detect-libc": "^2.0.3",
    "esbuild": "^0.25.0",
    "typescript": "^6.0.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "difit.openReview",
        "title": "difit: Open Review",
        "icon": {
          "light": "assets/favicon.svg",
          "dark": "assets/favicon-white.svg"
        }
      },
      {
        "command": "difit.stopReview",
        "title": "difit: Stop Review"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "difit.openReview",
          "group": "navigation@100"
        }
      ]
    },
    "configuration": {
      "title": "difit",
      "properties": {
        "difit.executablePath": {
          "type": "string",
          "default": "",
          "description": "Optional path to an external difit executable. Leave empty to use the difit version bundled with this extension."
        }
      }
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "assets/logo.png",
  "engines": {
    "vscode": "^1.102.0"
  }
}
